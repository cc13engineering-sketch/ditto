{
  "name": "ditto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Directive-driven Claude Code prompt modification, with named variants",
  "bin": {
    "ditto": "bin/ditto"
  },
  "engines": {
    "bun": ">=1.1"
  },
  "scripts": {
    "update-skill": "mkdir -p ~/.claude/skills && rsync -a --delete skill/ ~/.claude/skills/ditto/"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0"
  }
}
